#!/usr/bin/env node
/**
 * git-web エントリスクリプト。
 *
 * `git web` として実行されると、このファイルが起動し、
 * - 同一リポジトリで既に起動中のインスタンスがあればその URL を出力し、
 *   ブラウザを開いて即終了する (ADR 0044)
 * - それ以外は api サーバーを 127.0.0.1 の空きポートで起動し、
 *   packages/front/dist を静的配信元としてマウント、
 *   レジストリに自身を登録してからブラウザを自動で開く
 *
 * 前提: ./bin/pnpm build 済み（packages/api/dist と
 * packages/front/dist の両方が存在すること）
 *
 * 環境変数:
 * - PORT: 待ち受けポートを明示指定する。未指定なら OS 自動割当 (port 0)。
 *   複数リポジトリの並行起動に影響しないよう、通常は未指定で問題ない。
 *   固定ポートが必要な用途（dev サーバーの vite proxy など）のための escape
 *   hatch として残している。経緯は ADR 0044 参照。
 */

import { spawn } from 'node:child_process'
import { existsSync, readFileSync } from 'node:fs'
import { dirname, resolve } from 'node:path'
import process from 'node:process'
import { fileURLToPath } from 'node:url'

const scriptPath = fileURLToPath(import.meta.url)
const repoRoot = dirname(dirname(scriptPath))
const apiMainPath = resolve(repoRoot, 'packages/api/dist/main.js')
const frontDistPath = resolve(repoRoot, 'packages/front/dist')

if (!existsSync(apiMainPath)) {
  console.error(`api is not built: ${apiMainPath} not found`)
  console.error('run "./bin/pnpm build" first')
  process.exit(1)
}

if (!existsSync(frontDistPath)) {
  console.error(`front is not built: ${frontDistPath} not found`)
  console.error('run "./bin/pnpm build" first')
  process.exit(1)
}

/**
 * @typedef {{ kind: 'existing', url: string, pid: number, repoRoot: string }} ExistingInstance
 * @typedef {{ kind: 'started', url: string, port: number, pid: number, repoRoot: string,
 *   close: () => Promise<void>, unregister: () => Promise<void>, unregisterSync: () => void }} StartedInstance
 * @typedef {ExistingInstance | StartedInstance} LaunchResult
 *
 * @type {{
 *   launch: (options: { cwd?: string; host?: string; port?: number; staticDir?: string }) => Promise<LaunchResult>,
 *   readPortFromEnv: (env: NodeJS.ProcessEnv) => number | undefined,
 * }}
 */
const apiModule = await import(apiMainPath)

const port = apiModule.readPortFromEnv(process.env)

try {
  const result = await apiModule.launch({
    cwd: process.cwd(),
    staticDir: frontDistPath,
    ...(port !== undefined ? { port } : {}),
  })

  if (result.kind === 'existing') {
    console.log(`git-web already running for this repository: ${result.url}`)
    console.log(`target repository: ${result.repoRoot}`)
    console.log(`existing pid: ${result.pid}`)
    openBrowser(result.url)
    process.exit(0)
  }

  console.log(`git-web listening on ${result.url}`)
  console.log(`target repository: ${result.repoRoot}`)
  openBrowser(result.url)

  // ADR 0045: ローカル専用 CLI では graceful shutdown の実益が無いため、
  // SIGINT / SIGTERM では同期 unregister と即時 exit のみ行う。
  // HTTP サーバの socket は OS が回収する。
  // exit code は POSIX 慣習に従い 128 + signal number を返す。
  /** @type {Record<'SIGINT' | 'SIGTERM', number>} */
  const SIGNAL_EXIT_CODES = { SIGINT: 130, SIGTERM: 143 }
  /**
   * @param {'SIGINT' | 'SIGTERM'} signal
   */
  const shutdown = (signal) => {
    result.unregisterSync()
    process.exit(SIGNAL_EXIT_CODES[signal])
  }
  process.on('SIGINT', () => shutdown('SIGINT'))
  process.on('SIGTERM', () => shutdown('SIGTERM'))
  // process.exit() 経由や uncaughtException 経由の終了で同期 unregister が
  // 走るよう保険を登録する。unregisterSync は idempotent なので二重呼び出しは
  // no-op となる。SIGKILL / segfault / 電源断では走らないが、そのケースは
  // 次回起動時の pruneStale で回収される (ADR 0044)
  process.on('exit', () => {
    result.unregisterSync()
  })
} catch (err) {
  console.error(err instanceof Error ? err.message : 'failed to start')
  process.exit(1)
}

/**
 * WSL (Windows Subsystem for Linux) 環境かどうかを判定する。
 * /proc/version に "microsoft" または "WSL" が含まれていれば WSL と見なす。
 * 読み取りに失敗した場合は非 WSL として扱う。
 *
 * @returns {boolean}
 */
function isWSL() {
  try {
    const version = readFileSync('/proc/version', 'utf8')
    return /microsoft|wsl/i.test(version)
  } catch {
    return false
  }
}

/**
 * OS に応じたブラウザ起動コマンドを実行する。
 * 失敗しても黙って握りつぶす（ユーザーが手動で URL を開けば良い）。
 *
 * WSL 環境では cmd.exe 経由で Windows 側のブラウザを開く（ADR 0036 参照）。
 *
 * @param {string} url
 */
function openBrowser(url) {
  const platform = process.platform
  let cmd
  let args
  if (platform === 'darwin') {
    cmd = 'open'
    args = [url]
  } else if (platform === 'win32') {
    cmd = 'cmd'
    args = ['/c', 'start', '', url]
  } else if (isWSL()) {
    cmd = 'cmd.exe'
    args = ['/c', 'start', '', url]
  } else {
    cmd = 'xdg-open'
    args = [url]
  }

  try {
    const child = spawn(cmd, args, { detached: true, stdio: 'ignore' })
    child.on('error', () => {
      // xdg-open が存在しない等
    })
    child.unref()
  } catch {
    // 握りつぶす
  }
}
