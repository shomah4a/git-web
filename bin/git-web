#!/usr/bin/env node
/**
 * git-web エントリスクリプト。
 *
 * `git web` として実行されると、このファイルが起動し、
 * - api サーバーを 127.0.0.1 の固定ポート (デフォルト 47906) で起動
 * - packages/front/dist を静的配信元としてマウント
 * - ブラウザを自動で開く
 *
 * 前提: ./bin/pnpm build 済み（packages/api/dist と
 * packages/front/dist の両方が存在すること）
 *
 * 環境変数:
 * - PORT: 待ち受けポートを上書きする。未指定ならデフォルトの 47906 を使う。
 *   固定ポートの選定理由は ADR 0013 参照。
 */

const DEFAULT_PORT = 47906

import { spawn } from 'node:child_process'
import { existsSync } from 'node:fs'
import { dirname, resolve } from 'node:path'
import process from 'node:process'
import { fileURLToPath } from 'node:url'

const scriptPath = fileURLToPath(import.meta.url)
const repoRoot = dirname(dirname(scriptPath))
const apiMainPath = resolve(repoRoot, 'packages/api/dist/main.js')
const frontDistPath = resolve(repoRoot, 'packages/front/dist')

if (!existsSync(apiMainPath)) {
  console.error(`api is not built: ${apiMainPath} not found`)
  console.error('run "./bin/pnpm build" first')
  process.exit(1)
}

if (!existsSync(frontDistPath)) {
  console.error(`front is not built: ${frontDistPath} not found`)
  console.error('run "./bin/pnpm build" first')
  process.exit(1)
}

/** @type {{ start: (options: { cwd?: string; staticDir?: string; port?: number }) => Promise<{ url: string; repoRoot: string; close: () => Promise<void> }> }} */
const apiModule = await import(apiMainPath)

const port = readPortFromEnv()

try {
  const started = await apiModule.start({
    cwd: process.cwd(),
    staticDir: frontDistPath,
    port,
  })

  console.log(`git-web listening on ${started.url}`)
  console.log(`target repository: ${started.repoRoot}`)

  openBrowser(started.url)

  // SIGINT / SIGTERM でクリーンシャットダウン
  const shutdown = async () => {
    try {
      await started.close()
    } catch (err) {
      // close が失敗しても終了自体は継続する。原因切り分けのために
      // ログは出しておく
      const message = err instanceof Error ? err.message : String(err)
      console.error(`failed to close server cleanly: ${message}`)
    }
    process.exit(0)
  }
  process.on('SIGINT', () => void shutdown())
  process.on('SIGTERM', () => void shutdown())
} catch (err) {
  console.error(err instanceof Error ? err.message : 'failed to start')
  process.exit(1)
}

/**
 * OS に応じたブラウザ起動コマンドを実行する。
 * 失敗しても黙って握りつぶす（ユーザーが手動で URL を開けば良い）。
 *
 * @param {string} url
 */
function openBrowser(url) {
  const platform = process.platform
  let cmd
  let args
  if (platform === 'darwin') {
    cmd = 'open'
    args = [url]
  } else if (platform === 'win32') {
    cmd = 'cmd'
    args = ['/c', 'start', '', url]
  } else {
    cmd = 'xdg-open'
    args = [url]
  }

  try {
    const child = spawn(cmd, args, { detached: true, stdio: 'ignore' })
    child.on('error', () => {
      // xdg-open が存在しない等
    })
    child.unref()
  } catch {
    // 握りつぶす
  }
}

/**
 * 環境変数 PORT から起動ポートを読む。
 * 未指定または不正な値なら DEFAULT_PORT (47906) を返す。
 * 固定ポート採用の背景は ADR 0013 参照。
 *
 * @returns {number}
 */
function readPortFromEnv() {
  const raw = process.env.PORT
  if (raw === undefined || raw === '') {
    return DEFAULT_PORT
  }
  const parsed = Number.parseInt(raw, 10)
  if (Number.isNaN(parsed) || parsed < 0 || parsed > 65535) {
    console.warn(`invalid PORT env value: ${raw}, falling back to ${DEFAULT_PORT}`)
    return DEFAULT_PORT
  }
  return parsed
}
