#!/usr/bin/env bash
#
# リポジトリローカル pnpm ラッパー
#
# 動作:
# - package.json の packageManager フィールドで指定された pnpm を使用する
# - corepack のキャッシュを ${REPO_ROOT}/.corepack に閉じ込める
#   ことで、システムやユーザーホームを汚さない
#
# 前提:
# - Node.js (corepack 同梱) がインストール済みであること
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

export COREPACK_HOME="${REPO_ROOT}/.corepack"
export COREPACK_ENABLE_DOWNLOAD_PROMPT=0

cd "${REPO_ROOT}"
exec corepack pnpm "$@"
