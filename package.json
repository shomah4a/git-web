{
  "name": "git-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "./bin/pnpm -r build",
    "test": "./bin/pnpm -r test",
    "lint": "eslint . --no-error-on-unmatched-pattern",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "./bin/pnpm -r typecheck",
    "check": "./bin/pnpm lint && ./bin/pnpm format:check && ./bin/pnpm typecheck && ./bin/pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.2",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.8.0",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vitest": "4.1.3",
    "vue-eslint-parser": "10.4.0"
  }
}
